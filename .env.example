# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/project_manager?schema=public"

# ============================================================
# DingTalk Server
# ============================================================
DINGTALK_CORP_ID=""
DINGTALK_CLIENT_ID=""
DINGTALK_CLIENT_SECRET=""
DINGTALK_AGENT_ID=""
DINGTALK_WEB_LOGIN_REDIRECT_URI="https://your-domain.com/api/auth/dingtalk-web/callback"

# ============================================================
# DingTalk Client
# ============================================================
NEXT_PUBLIC_DINGTALK_CORP_ID=""
NEXT_PUBLIC_DINGTALK_CLIENT_ID=""

# ============================================================
# System Manager Whitelist
# Keep backend and frontend values aligned.
# ============================================================
SYSTEM_MANAGER_DING_USER_IDS="manager_ding_user_id_1,manager_ding_user_id_2"
NEXT_PUBLIC_SYSTEM_MANAGER_DING_USER_IDS="manager_ding_user_id_1,manager_ding_user_id_2"

# ============================================================
# Fresh environment bootstrap admin
# If there is no ADMIN in SystemUser yet, init:system will use these values
# to create or upgrade the first system administrator.
# ============================================================
BOOTSTRAP_ADMIN_DING_USER_ID=""
BOOTSTRAP_ADMIN_NAME=""
BOOTSTRAP_ADMIN_MOBILE=""

# ============================================================
# Alibaba OSS
# Required because mature contract/receipt pages already support attachments.
# ============================================================
OSS_REGION=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
OSS_CUSTOM_DOMAIN=""

# ============================================================
# Runtime
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# Local development only
# ============================================================
DEV_AUTH_ROLE=ADMIN
DEV_AUTH_DING_USER_ID=local-dev-admin
DEV_AUTH_USER_NAME=本地开发管理员
