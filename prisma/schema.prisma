generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActionLog {
  id         String     @id
  userId     String?
  userName   String
  userRole   String
  action     ActionType
  resource   String
  resourceId String?
  method     String
  path       String
  detail     String?
  createdAt  DateTime   @default(now())

  @@index([createdAt])
  @@index([resource])
  @@index([userId])
}

model ConstructionApproval {
  id                  String                @id
  projectId           String
  contractId          String
  code                String                @unique
  name                String
  budget              Decimal               @db.Decimal(18, 2)
  status              String                @default("active")
  startDate           DateTime?
  endDate             DateTime?
  approvalStatus      String                @default("APPROVED")
  submittedAt         DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectedReason      String?
  remark              String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  regionId            String?
  formDataJson        String?
  ProjectContract     ProjectContract       @relation(fields: [contractId], references: [id])
  Project             Project               @relation(fields: [projectId], references: [id])
  Region              Region?               @relation(fields: [regionId], references: [id])
  LaborContract       LaborContract[]
  ProcurementContract ProcurementContract[]
  ProjectExpense      ProjectExpense[]
  SubcontractContract SubcontractContract[]

  @@index([approvalStatus])
  @@index([code])
  @@index([contractId])
  @@index([projectId])
}

model ContractReceipt {
  id              String          @id
  contractId      String
  receiptDate     DateTime
  remark          String?
  createdAt       DateTime        @default(now())
  receiptAmount   Decimal         @db.Decimal(18, 2)
  receiptMethod   String?
  receiptNumber   String?
  status          ReceiptStatus   @default(UNRECEIVED)
  updatedAt       DateTime
  regionId        String?
  approvalStatus  String          @default("PENDING")
  approvedAt      DateTime?
  attachmentUrl   String?
  deductionItems  String?
  rejectedAt      DateTime?
  rejectedReason  String?
  submittedAt     DateTime?
  ProjectContract ProjectContract @relation(fields: [contractId], references: [id])
  Region          Region?         @relation(fields: [regionId], references: [id])

  @@index([contractId])
  @@index([receiptDate])
}

model Customer {
  id              String            @id
  name            String
  contact         String?
  phone           String?
  email           String?
  address         String?
  remark          String?
  createdAt       DateTime          @default(now())
  bankAccount     String?
  bankName        String?
  code            String            @unique
  status          String            @default("active")
  taxId           String?
  updatedAt       DateTime
  regionId        String?
  Project         Project[]
  ProjectContract ProjectContract[]
  Region          Region?           @relation(fields: [regionId], references: [id])

  @@index([code])
  @@index([name])
  @@index([regionId])
}

model FormDefinition {
  id        String      @id
  name      String
  code      String      @unique
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  FormField FormField[]

  @@index([code])
}

model FormField {
  id               String         @id
  formId           String
  label            String
  fieldKey         String
  componentType    String
  required         Boolean        @default(false)
  optionsJson      String?
  sortOrder        Int
  createdAt        DateTime       @default(now())
  computeFormula   String?
  dependsOn        String?
  dependsValue     String?
  isReadonly       Boolean        @default(false)
  linkedCopyFields String?
  linkedLabelField String?
  linkedTable      String?
  linkedValueField String?
  placeholder      String?
  tableColumnsJson String?
  FormDefinition   FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([formId, sortOrder])
}

model LaborContract {
  id                   String               @id
  constructionId       String
  name                 String
  code                 String               @unique
  signDate             DateTime?
  remark               String?
  createdAt            DateTime             @default(now())
  approvalStatus       String               @default("APPROVED")
  approvedAt           DateTime?
  changedAmount        Decimal              @default(0) @db.Decimal(18, 2)
  contractAmount       Decimal              @db.Decimal(18, 2)
  endDate              DateTime?
  paidAmount           Decimal              @default(0) @db.Decimal(18, 2)
  payableAmount        Decimal              @default(0) @db.Decimal(18, 2)
  projectId            String
  rejectedAt           DateTime?
  rejectedReason       String?
  startDate            DateTime?
  submittedAt          DateTime?
  unpaidAmount         Decimal              @default(0) @db.Decimal(18, 2)
  updatedAt            DateTime
  workerId             String
  status               ContractStatus       @default(DRAFT)
  regionId             String?
  attachmentUrl        String?
  laborType            String?
  ConstructionApproval ConstructionApproval @relation(fields: [constructionId], references: [id])
  Project              Project              @relation(fields: [projectId], references: [id])
  Region               Region?              @relation(fields: [regionId], references: [id])
  LaborWorker          LaborWorker          @relation(fields: [workerId], references: [id])
  LaborPayment         LaborPayment[]

  @@index([approvalStatus])
  @@index([code])
  @@index([constructionId])
  @@index([projectId])
  @@index([status])
  @@index([workerId])
}

model LaborPayment {
  id             String        @id
  contractId     String
  remark         String?
  createdAt      DateTime      @default(now())
  approvalStatus String        @default("APPROVED")
  approvedAt     DateTime?
  paymentAmount  Decimal       @db.Decimal(18, 2)
  paymentDate    DateTime
  paymentMethod  String?
  paymentNumber  String?
  projectId      String
  rejectedAt     DateTime?
  rejectedReason String?
  status         PaymentStatus @default(UNPAID)
  submittedAt    DateTime?
  updatedAt      DateTime
  workerId       String
  regionId       String?
  attachmentUrl  String?
  LaborContract  LaborContract @relation(fields: [contractId], references: [id])
  Project        Project       @relation(fields: [projectId], references: [id])
  Region         Region?       @relation(fields: [regionId], references: [id])
  LaborWorker    LaborWorker   @relation(fields: [workerId], references: [id])

  @@index([approvalStatus])
  @@index([contractId])
  @@index([paymentDate])
  @@index([projectId])
  @@index([workerId])
}

model LaborWorker {
  id            String          @id
  code          String          @unique
  name          String
  idNumber      String?
  phone         String?
  address       String?
  bankAccount   String?
  bankName      String?
  status        String          @default("active")
  remark        String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  attachmentUrl String?
  regionId      String?
  LaborContract LaborContract[]
  LaborPayment  LaborPayment[]
  SubcontractContract SubcontractContract[]
  SubcontractPayment  SubcontractPayment[]
  Region        Region?         @relation(fields: [regionId], references: [id])

  @@index([code])
  @@index([name])
  @@index([regionId])
}

model ManagementExpense {
  id             String    @id
  projectId      String?
  regionId       String?
  category       String
  expenseDate    DateTime
  description    String?
  remark         String?
  createdAt      DateTime  @default(now())
  expenseAmount  Decimal   @db.Decimal(18, 2)
  updatedAt      DateTime
  approvalStatus String    @default("PENDING")
  approvedAt     DateTime?
  attachmentUrl  String?
  expenseItems   String?
  rejectedAt     DateTime?
  rejectedReason String?
  submittedAt    DateTime?
  submitter      String?
  totalAmount    Decimal?  @db.Decimal(18, 2)
  Project        Project?  @relation(fields: [projectId], references: [id])
  Region         Region?   @relation(fields: [regionId], references: [id])

  @@index([expenseDate])
  @@index([projectId])
  @@index([regionId])
}

model OrganizationUnit {
  id                     String              @id
  name                   String
  code                   String?             @unique
  parentId               String?
  isActive               Boolean             @default(true)
  remark                 String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime
  OrganizationUnit       OrganizationUnit?   @relation("OrganizationUnitToOrganizationUnit", fields: [parentId], references: [id])
  other_OrganizationUnit OrganizationUnit[]  @relation("OrganizationUnitToOrganizationUnit")
  SystemUserOrgUnit      SystemUserOrgUnit[]

  @@index([parentId])
}

model OtherPayment {
  id             String        @id
  projectId      String?
  regionId       String?
  paymentType    String
  paymentAmount  Decimal       @db.Decimal(18, 2)
  paymentDate    DateTime
  paymentMethod  String?
  paymentNumber  String?
  status         PaymentStatus @default(UNPAID)
  remark         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  approvalStatus String        @default("PENDING")
  approvedAt     DateTime?
  attachmentUrl  String?
  rejectedAt     DateTime?
  rejectedReason String?
  submittedAt    DateTime?
  Project        Project?      @relation(fields: [projectId], references: [id])
  Region         Region?       @relation(fields: [regionId], references: [id])

  @@index([paymentDate])
  @@index([projectId])
  @@index([regionId])
}

model OtherReceipt {
  id             String    @id
  projectId      String?
  regionId       String?
  receiptType    String
  receiptAmount  Decimal   @db.Decimal(18, 2)
  receiptDate    DateTime
  receiptMethod  String?
  receiptNumber  String?
  remark         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  approvalStatus String    @default("PENDING")
  approvedAt     DateTime?
  attachmentUrl  String?
  rejectedAt     DateTime?
  rejectedReason String?
  submittedAt    DateTime?
  Project        Project?  @relation(fields: [projectId], references: [id])
  Region         Region?   @relation(fields: [regionId], references: [id])

  @@index([projectId])
  @@index([regionId])
  @@index([receiptDate])
}

model PettyCash {
  id             String          @id
  holder         String
  issueDate      DateTime
  returnDate     DateTime?
  description    String?
  remark         String?
  createdAt      DateTime        @default(now())
  issuedAmount   Decimal         @db.Decimal(18, 2)
  projectId      String?
  regionId       String?
  returnedAmount Decimal         @default(0) @db.Decimal(18, 2)
  status         PettyCashStatus @default(ISSUED)
  updatedAt      DateTime
  applyReason    String?
  approvalStatus String          @default("PENDING")
  approvedAt     DateTime?
  attachmentUrl  String?
  rejectedAt     DateTime?
  rejectedReason String?
  submittedAt    DateTime?
  Project        Project?        @relation(fields: [projectId], references: [id])
  Region         Region?         @relation(fields: [regionId], references: [id])

  @@index([issueDate])
  @@index([projectId])
  @@index([regionId])
}

model ProcessDefinition {
  id              String            @id
  resourceType    String            @unique
  name            String
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  ProcessInstance ProcessInstance[]
  ProcessNode     ProcessNode[]

  @@index([resourceType])
}

model ProcessInstance {
  id                String                @id
  definitionId      String
  resourceType      String
  resourceId        String
  submitterUserId   String
  submitterName     String
  status            ProcessInstanceStatus @default(PENDING)
  startedAt         DateTime              @default(now())
  finishedAt        DateTime?
  ProcessDefinition ProcessDefinition     @relation(fields: [definitionId], references: [id])
  ProcessTask       ProcessTask[]

  @@index([resourceType, resourceId])
  @@index([status])
}

model ProcessNode {
  id                String                  @id
  definitionId      String
  order             Int
  name              String                  @default("审批")
  approverType      ProcessNodeApproverType @default(ROLE)
  approverRole      String?
  approverUserId    String?
  ccMode            ProcessNodeCcMode       @default(NONE)
  ccRole            String?
  ccUserId          String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime
  ProcessDefinition ProcessDefinition       @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  ProcessTask       ProcessTask[]

  @@index([definitionId, order])
}

model ProcessTask {
  id              String                  @id
  instanceId      String
  nodeId          String
  nodeOrder       Int
  approverType    ProcessNodeApproverType
  approverRole    String?
  approverUserId  String?
  status          ProcessTaskStatus       @default(PENDING)
  comment         String?
  handledAt       DateTime?
  handledBy       String?
  createdAt       DateTime                @default(now())
  ProcessInstance ProcessInstance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  ProcessNode     ProcessNode             @relation(fields: [nodeId], references: [id])

  @@index([instanceId])
  @@index([nodeId])
  @@index([status])
}

model ProcurementContract {
  id                   String               @id
  constructionId       String
  supplierId           String
  name                 String
  code                 String               @unique
  signDate             DateTime?
  remark               String?
  createdAt            DateTime             @default(now())
  approvalStatus       String               @default("APPROVED")
  approvedAt           DateTime?
  changedAmount        Decimal              @default(0) @db.Decimal(18, 2)
  contractAmount       Decimal              @db.Decimal(18, 2)
  endDate              DateTime?
  paidAmount           Decimal              @default(0) @db.Decimal(18, 2)
  payableAmount        Decimal              @default(0) @db.Decimal(18, 2)
  projectId            String
  rejectedAt           DateTime?
  rejectedReason       String?
  startDate            DateTime?
  submittedAt          DateTime?
  unpaidAmount         Decimal              @default(0) @db.Decimal(18, 2)
  updatedAt            DateTime
  status               ContractStatus       @default(DRAFT)
  regionId             String?
  attachmentUrl        String?
  materialCategory     String?
  ConstructionApproval ConstructionApproval @relation(fields: [constructionId], references: [id])
  Project              Project              @relation(fields: [projectId], references: [id])
  Region               Region?              @relation(fields: [regionId], references: [id])
  Supplier             Supplier             @relation(fields: [supplierId], references: [id])
  ProcurementPayment   ProcurementPayment[]

  @@index([code])
  @@index([constructionId])
  @@index([projectId])
  @@index([status])
  @@index([supplierId])
}

model ProcurementPayment {
  id                  String              @id
  contractId          String
  remark              String?
  createdAt           DateTime            @default(now())
  approvalStatus      String              @default("APPROVED")
  approvedAt          DateTime?
  paymentAmount       Decimal             @db.Decimal(18, 2)
  paymentDate         DateTime
  paymentMethod       String?
  paymentNumber       String?
  projectId           String
  rejectedAt          DateTime?
  rejectedReason      String?
  status              PaymentStatus       @default(UNPAID)
  submittedAt         DateTime?
  updatedAt           DateTime
  regionId            String?
  attachmentUrl       String?
  ProcurementContract ProcurementContract @relation(fields: [contractId], references: [id])
  Project             Project             @relation(fields: [projectId], references: [id])
  Region              Region?             @relation(fields: [regionId], references: [id])

  @@index([approvalStatus])
  @@index([contractId])
  @@index([paymentDate])
  @@index([projectId])
}

model Project {
  id                   String                 @id
  name                 String
  code                 String                 @unique
  customerId           String
  startDate            DateTime?
  endDate              DateTime?
  remark               String?
  createdAt            DateTime               @default(now())
  budget               Decimal                @db.Decimal(18, 2)
  updatedAt            DateTime
  status               ProjectStatus          @default(IN_PROGRESS)
  regionId             String?
  area                 Decimal?               @db.Decimal(18, 2)
  bidMethod            String?
  location             String?
  projectType          String?
  approvalStatus       String                 @default("APPROVED")
  approvedAt           DateTime?
  rejectedAt           DateTime?
  rejectedReason       String?
  submittedAt          DateTime?
  ConstructionApproval ConstructionApproval[]
  LaborContract        LaborContract[]
  LaborPayment         LaborPayment[]
  ManagementExpense    ManagementExpense[]
  OtherPayment         OtherPayment[]
  OtherReceipt         OtherReceipt[]
  PettyCash            PettyCash[]
  ProcurementContract  ProcurementContract[]
  ProcurementPayment   ProcurementPayment[]
  Customer             Customer               @relation(fields: [customerId], references: [id])
  Region               Region?                @relation(fields: [regionId], references: [id])
  ProjectContract      ProjectContract[]
  ProjectExpense       ProjectExpense[]
  ProjectStatusChange  ProjectStatusChange[]
  SalesExpense         SalesExpense[]
  SubcontractContract  SubcontractContract[]
  SubcontractPayment   SubcontractPayment[]

  @@index([approvalStatus])
  @@index([code])
  @@index([customerId])
  @@index([status])
}

model ProjectContract {
  id                    String                  @id
  projectId             String
  name                  String
  code                  String                  @unique
  signDate              DateTime?
  remark                String?
  createdAt             DateTime                @default(now())
  changedAmount         Decimal                 @default(0) @db.Decimal(18, 2)
  contractAmount        Decimal                 @db.Decimal(18, 2)
  customerId            String
  endDate               DateTime?
  receivableAmount      Decimal                 @default(0) @db.Decimal(18, 2)
  receivedAmount        Decimal                 @default(0) @db.Decimal(18, 2)
  startDate             DateTime?
  unreceivedAmount      Decimal                 @default(0) @db.Decimal(18, 2)
  updatedAt             DateTime
  status                ContractStatus          @default(DRAFT)
  regionId              String?
  attachmentUrl         String?
  contractType          String?
  hasRetention          Boolean                 @default(false)
  paymentMethod         String?
  retentionAmount       Decimal?                @db.Decimal(18, 2)
  retentionRate         Decimal?                @db.Decimal(5, 2)
  approvalStatus        String                  @default("APPROVED")
  approvedAt            DateTime?
  rejectedAt            DateTime?
  rejectedReason        String?
  submittedAt           DateTime?
  ConstructionApproval  ConstructionApproval[]
  ContractReceipt       ContractReceipt[]
  Customer              Customer                @relation(fields: [customerId], references: [id])
  Project               Project                 @relation(fields: [projectId], references: [id])
  Region                Region?                 @relation(fields: [regionId], references: [id])
  ProjectContractChange ProjectContractChange[]

  @@index([approvalStatus])
  @@index([code])
  @@index([customerId])
  @@index([projectId])
  @@index([status])
}

model ProjectContractChange {
  id              String          @id
  contractId      String
  regionId        String?
  changeType      ChangeType
  changeAmount    Decimal         @db.Decimal(18, 2)
  changeReason    String?
  remark          String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  approvalStatus  String          @default("PENDING")
  approvedAt      DateTime?
  attachmentUrl   String?
  changeDate      DateTime?
  increaseAmount  Decimal?        @db.Decimal(18, 2)
  originalAmount  Decimal?        @db.Decimal(18, 2)
  rejectedAt      DateTime?
  rejectedReason  String?
  submittedAt     DateTime?
  totalAmount     Decimal?        @db.Decimal(18, 2)
  ProjectContract ProjectContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  Region          Region?         @relation(fields: [regionId], references: [id])

  @@index([contractId])
  @@index([createdAt])
  @@index([regionId])
}

model ProjectExpense {
  id             String          @id
  expenseDate    DateTime
  description    String?
  remark         String?
  createdAt      DateTime        @default(now())
  expenseAmount  Decimal         @db.Decimal(18, 2)
  constructionId String?
  projectId      String
  updatedAt      DateTime
  category       ExpenseCategory
  approvalStatus String          @default("PENDING")
  approvedAt     DateTime?
  attachmentUrl  String?
  expenseItems   String?
  rejectedAt     DateTime?
  rejectedReason String?
  submittedAt    DateTime?
  submitter      String?
  totalAmount    Decimal?        @db.Decimal(18, 2)
  ConstructionApproval ConstructionApproval? @relation(fields: [constructionId], references: [id])
  Project        Project         @relation(fields: [projectId], references: [id])

  @@index([category])
  @@index([constructionId])
  @@index([expenseDate])
  @@index([projectId])
}

model ProjectStatusChange {
  id           String        @id
  projectId    String
  fromStatus   ProjectStatus
  toStatus     ProjectStatus
  changeReason String?
  remark       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  Project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([projectId])
}

model Region {
  id                   String                 @id
  name                 String
  code                 String?                @unique
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  ConstructionApproval ConstructionApproval[]
  ContractReceipt      ContractReceipt[]
  Customer             Customer[]
  LaborContract        LaborContract[]
  LaborPayment         LaborPayment[]
  LaborWorker          LaborWorker[]
  ManagementExpense    ManagementExpense[]
  OtherPayment         OtherPayment[]
  OtherReceipt         OtherReceipt[]
  PettyCash            PettyCash[]
  ProcurementContract  ProcurementContract[]
  ProcurementPayment   ProcurementPayment[]
  Project              Project[]
  ProjectContractChange ProjectContractChange[]
  ProjectContract      ProjectContract[]
  SalesExpense         SalesExpense[]
  SubcontractContract  SubcontractContract[]
  SubcontractPayment   SubcontractPayment[]
  SubcontractVendor    SubcontractVendor[]
  Supplier             Supplier[]

  @@index([isActive])
}

model SalesExpense {
  id             String    @id
  projectId      String?
  regionId       String?
  category       String
  expenseDate    DateTime
  description    String?
  remark         String?
  createdAt      DateTime  @default(now())
  expenseAmount  Decimal   @db.Decimal(18, 2)
  updatedAt      DateTime
  approvalStatus String    @default("PENDING")
  approvedAt     DateTime?
  attachmentUrl  String?
  expenseItems   String?
  rejectedAt     DateTime?
  rejectedReason String?
  submittedAt    DateTime?
  submitter      String?
  totalAmount    Decimal?  @db.Decimal(18, 2)
  Project        Project?  @relation(fields: [projectId], references: [id])
  Region         Region?   @relation(fields: [regionId], references: [id])

  @@index([expenseDate])
  @@index([projectId])
  @@index([regionId])
}

model SubcontractContract {
  id                   String               @id
  constructionId       String
  name                 String
  code                 String               @unique
  signDate             DateTime?
  remark               String?
  createdAt            DateTime             @default(now())
  approvalStatus       String               @default("APPROVED")
  approvedAt           DateTime?
  changedAmount        Decimal              @default(0) @db.Decimal(18, 2)
  contractAmount       Decimal              @db.Decimal(18, 2)
  endDate              DateTime?
  paidAmount           Decimal              @default(0) @db.Decimal(18, 2)
  payableAmount        Decimal              @default(0) @db.Decimal(18, 2)
  projectId            String
  rejectedAt           DateTime?
  rejectedReason       String?
  startDate            DateTime?
  submittedAt          DateTime?
  unpaidAmount         Decimal              @default(0) @db.Decimal(18, 2)
  updatedAt            DateTime
  vendorId             String?
  workerId             String?
  status               ContractStatus       @default(DRAFT)
  regionId             String?
  attachmentUrl        String?
  subcontractType      String?
  ConstructionApproval ConstructionApproval @relation(fields: [constructionId], references: [id])
  Project              Project              @relation(fields: [projectId], references: [id])
  Region               Region?              @relation(fields: [regionId], references: [id])
  SubcontractVendor    SubcontractVendor?   @relation(fields: [vendorId], references: [id])
  LaborWorker          LaborWorker?         @relation(fields: [workerId], references: [id])
  SubcontractPayment   SubcontractPayment[]

  @@index([approvalStatus])
  @@index([code])
  @@index([constructionId])
  @@index([projectId])
  @@index([status])
  @@index([vendorId])
  @@index([workerId])
}

model SubcontractPayment {
  id                  String              @id
  contractId          String
  remark              String?
  createdAt           DateTime            @default(now())
  approvalStatus      String              @default("APPROVED")
  approvedAt          DateTime?
  paymentAmount       Decimal             @db.Decimal(18, 2)
  paymentDate         DateTime
  paymentMethod       String?
  paymentNumber       String?
  projectId           String
  rejectedAt          DateTime?
  rejectedReason      String?
  status              PaymentStatus       @default(UNPAID)
  submittedAt         DateTime?
  updatedAt           DateTime
  vendorId            String?
  workerId            String?
  regionId            String?
  attachmentUrl       String?
  SubcontractContract SubcontractContract @relation(fields: [contractId], references: [id])
  Project             Project             @relation(fields: [projectId], references: [id])
  Region              Region?             @relation(fields: [regionId], references: [id])
  SubcontractVendor   SubcontractVendor?  @relation(fields: [vendorId], references: [id])
  LaborWorker         LaborWorker?        @relation(fields: [workerId], references: [id])

  @@index([approvalStatus])
  @@index([contractId])
  @@index([paymentDate])
  @@index([projectId])
  @@index([vendorId])
  @@index([workerId])
}

model SubcontractVendor {
  id                  String                @id
  code                String                @unique
  name                String
  contact             String?
  phone               String?
  email               String?
  address             String?
  taxId               String?
  bankAccount         String?
  bankName            String?
  status              String                @default("active")
  remark              String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  regionId            String?
  SubcontractContract SubcontractContract[]
  SubcontractPayment  SubcontractPayment[]
  Region              Region?               @relation(fields: [regionId], references: [id])

  @@index([code])
  @@index([name])
  @@index([regionId])
}

model Supplier {
  id                  String                @id
  name                String
  contact             String?
  phone               String?
  email               String?
  address             String?
  remark              String?
  createdAt           DateTime              @default(now())
  bankAccount         String?
  bankName            String?
  code                String                @unique
  status              String                @default("active")
  taxId               String?
  updatedAt           DateTime
  attachmentUrl       String?
  regionId            String?
  ProcurementContract ProcurementContract[]
  Region              Region?               @relation(fields: [regionId], references: [id])

  @@index([code])
  @@index([name])
  @@index([regionId])
}

model SystemUser {
  id                String              @id
  dingUserId        String              @unique
  name              String
  mobile            String?
  unionid           String?
  role              SystemUserRole      @default(STAFF)
  isActive          Boolean             @default(true)
  deptIdsJson       String?
  deptNamesJson     String?
  lastLoginAt       DateTime?
  remark            String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  SystemUserOrgUnit SystemUserOrgUnit[]

  @@index([createdAt])
  @@index([dingUserId])
  @@index([isActive])
  @@index([role])
}

model SystemUserOrgUnit {
  id               String           @id
  systemUserId     String
  orgUnitId        String
  createdAt        DateTime         @default(now())
  OrganizationUnit OrganizationUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  SystemUser       SystemUser       @relation(fields: [systemUserId], references: [id], onDelete: Cascade)

  @@unique([systemUserId, orgUnitId])
  @@index([orgUnitId])
}

